# Django
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production only — comma-separated https origins, e.g. https://aura-archives.com
CSRF_TRUSTED_ORIGINS=

# Database
DATABASE_URL=postgres://aura_user:aura_password@localhost:5432/aura_archives_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Aura Archives <hello@aura-archives.com>

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# AWS S3 (Production)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=aura-archives-media
AWS_S3_REGION_NAME=ap-south-1

# Unsplash API
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Pexels API
PEXELS_API_KEY=your-pexels-api-key

# Sentry (Production)
SENTRY_DSN=

# Site
SITE_URL=http://localhost:8000
SITE_NAME=Aura Archives
