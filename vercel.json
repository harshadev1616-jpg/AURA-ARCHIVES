{
  "version": 2,
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "buildCommand": "bash build.sh",
  "builds": [
    {
      "src": "aura_archives/wsgi.py",
      "use": "@vercel/python@3.11"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "aura_archives/wsgi.py"
    }
  ]
}
